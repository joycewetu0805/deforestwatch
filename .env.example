# ── Google Earth Engine ──
# Compte de service GEE (optionnel : laissé vide => mode données synthétiques)
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=config/gee-key.json

# ── Base de données (PostgreSQL / Supabase) ──
DATABASE_URL=postgresql://postgres:deforestwatch_dev@localhost:5432/deforestwatch
SUPABASE_URL=
SUPABASE_KEY=

# ── OpenWeatherMap ──
OPENWEATHER_API_KEY=

# ── Authentification ──
# ⚠️ En production, générez un secret aléatoire long (ex. `openssl rand -hex 32`).
# L'API refuse de démarrer en production si ce secret reste à sa valeur par défaut.
JWT_SECRET_KEY=change-this-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# 2FA imposée à la connexion. En mode démo, le code statique 123456 est accepté.
# Mettre REQUIRE_2FA=false désactive la 2FA (déconseillé).
REQUIRE_2FA=true
DEMO_OTP_CODE=123456

# Bootstrap d'un compte admin en production (optionnel).
# Renseignez ces deux variables pour créer un admin au premier démarrage.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── CORS ── origines autorisées, séparées par des virgules.
# "*" (défaut, dev/démo) est refusé en production par le fail-fast.
CORS_ORIGINS=*

# ── Application ──
# app_env=production active les contrôles de sécurité au démarrage (fail-fast).
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
STREAMLIT_PORT=8501

# Active le mode démo (données synthétiques, aucune dépendance externe requise)
DEMO_MODE=true

# ── Notifications e-mail des alertes (désactivé par défaut) ──
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=          # destinataires séparés par des virgules

# ── Zone d'étude (Mai-Ndombe, Inongo) ──
STUDY_AREA_LAT=-1.95
STUDY_AREA_LON=18.27
STUDY_AREA_BUFFER_KM=25
