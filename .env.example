# ── Google Earth Engine ──
# Compte de service GEE (optionnel : laissé vide => mode données synthétiques)
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=config/gee-key.json

# ── Base de données (PostgreSQL / Supabase) ──
DATABASE_URL=postgresql://postgres:deforestwatch_dev@localhost:5432/deforestwatch
SUPABASE_URL=
SUPABASE_KEY=

# ── OpenWeatherMap ──
OPENWEATHER_API_KEY=

# ── Authentification ──
JWT_SECRET_KEY=change-this-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Application ──
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
STREAMLIT_PORT=8501

# Active le mode démo (données synthétiques, aucune dépendance externe requise)
DEMO_MODE=true

# ── Notifications e-mail des alertes (désactivé par défaut) ──
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=          # destinataires séparés par des virgules

# ── Zone d'étude (Mai-Ndombe, Inongo) ──
STUDY_AREA_LAT=-1.95
STUDY_AREA_LON=18.27
STUDY_AREA_BUFFER_KM=25
